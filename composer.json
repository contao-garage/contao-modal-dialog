{
    "name": "contao-garage/contao-modal-dialog",
    "description": "Adds a modal pop up dialog to content elements.",
    "type": "contao-bundle",
    "keywords": ["contao bundle", "modal dialog"],
    "support": {
        "issues": "https://github.com/contao-garage/contao-modal-dialog/issues",
        "source": "https://github.com/contao-garage/contao-modal-dialog"
    },
    "homepage": "https://contao-garage.de",
    "license": "MIT",
    "authors": [
        {
            "name": "Martin Schumann",
            "homepage": "https://github.com/martinschumann"
        }
    ],
    "require": {
        "php": "^8.1",
        "contao/core-bundle": "^5.3",
        "contao-garage/contao-vue-js": "^3.5"
    },
    "autoload": {
        "psr-4": {
            "ContaoGarage\\ModalDialog\\": "src/"
        },
        "classmap": [
            "contao/"
        ],
        "exclude-from-classmap": [
            "contao/dca/",
            "contao/languages/",
            "contao/templates/"
        ]
    },
    "extra": {
        "contao-manager-plugin": "ContaoGarage\\ModalDialog\\ContaoManager\\Plugin"
    },
    "require-dev": {
        "contao/easy-coding-standard": "^6.13",
        "contao/rector": "^1.3"
    },
    "config": {
        "allow-plugins": {
            "contao-components/installer": true,
            "php-http/discovery": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
